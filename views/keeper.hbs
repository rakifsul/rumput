<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="row">
            <div class="col-12 mb-2">
                <button class="btn btn-dark btn-sm w-100" data-bs-toggle="modal" data-bs-target="#itemModal">
                    <i class="bi bi-plus-lg"></i> Add Note
                </button>
            </div>
        </div>

        <hr>

        <div class="row g-4" id="dashboardGrid">
            {{#each note}}
            <div class="col-12 col-md-6 col-lg-6 dashboard-card" id="{{this.id}}" data-title="{{this.title}}"
                data-note="{{this.note}}">
                <div class="card text-center h-100 border-0 shadow-sm bg-dark">
                    <div class="card-body">
                        <h6 class="mt-3 text-light">{{this.title}}</h6>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
    <div class="col-12 col-lg-4 border-separator d-none d-lg-block d-xl-block d-xxl-block">
        <h2 class="text-dark">Helpers</h2>
        <p>This is Keepers page. You can write notes here. To edit the notes, right click on the note card, and click
            edit.</p>
    </div>
</div>

<!-- Modal Tambah/Edit -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="itemForm" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add / Edit Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editIndex">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" id="titleInput" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Note</label>

                    <br>
                    <a href="javascript:void(0);" id="gen-datetime" class="badge bg-dark">datetime</a>

                    <textarea class="form-control mt-1" id="noteInput" rows="12"
                        placeholder="Write your notes here..."></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

<!-- Context Menu -->
<div id="contextMenu" class="dropdown-menu shadow">
    <button class="dropdown-item" id="trigger-edit">Edit</button>
    <button class="dropdown-item text-danger" id="trigger-delete">Delete</button>
</div>

<script>
    $(document).ready(function () {

        let $currentCard = null;

        // Klik kanan pada card
        $(document).on("contextmenu", ".dashboard-card", function (e) {
            e.preventDefault();
            $currentCard = $(this);

            $("#contextMenu")
                .css({ top: e.pageY, left: e.pageX })
                .show();
        });

        // Klik di luar -> tutup menu
        $(document).click(function () {
            $("#contextMenu").hide();
        });

        $("#trigger-edit").click(function () {
            $("#titleInput").val($currentCard.attr("data-title"));
            $("#noteInput").val(decodeURIComponent($currentCard.attr("data-note")));
            $("#itemModal").modal("show");
        });
        /*
        $("#trigger-run").click(function () {
            try {
                const scr = decodeURIComponent($currentCard.attr("data-note"));
                eval(scr);
            } catch (err) {
                console.log(err)
            }
        })*/

        $(".dashboard-card").click(function () {
            $currentCard = $(this);
            $("#titleInput").val($currentCard.attr("data-title"));
            $("#noteInput").val(decodeURIComponent($currentCard.attr("data-note")));
            $("#itemModal").modal("show");
        })
        

        $("#trigger-delete").click(async function () {
            if (confirm("WARNING! Note will be DELETED. Is it OK?")) {
                console.log("User chooses OK");

                //
                $currentCard.remove();
                $currentCard = null;
                await saveTriggersToServer();
            } else {
                console.log("User chooses Cancel");
                return;
            }
        });

        // Tombol Tambah → selalu reset ke mode Add
        $("[data-bs-target='#itemModal']").on("click", function () {
            $currentCard = null;
            $("#itemForm")[0].reset();
        });
        // Tambah/Edit Submit
        $("#itemForm").on("submit", async function (e) {
            e.preventDefault();
            const id = "no-id";//"launcher-" + Date.now();
            console.log(id)
            const title = $("#titleInput").val();
            const note = $("#noteInput").val();
            console.log(note)

            if ($currentCard) {
                // Edit existing card.
                //alert('sdsdfd ' + title)
                $currentCard.attr("data-title", title);
                $currentCard.attr("data-note", encodeURIComponent(note));
            } else {
                // Add new card
                const newCard = $(`
                    <div class="col-12 col-md-6 col-lg-6 dashboard-card" id="${id}" data-title="${title}" data-note="${encodeURIComponent(note)}">
                        <div class="card text-center h-100 border-0 shadow-sm bg-dark">
                            <div class="card-body">
                                <h6 class="mt-3 text-light">${title}</h6>
                            </div>
                        </div>
                    </div>
                `);
                $("#dashboardGrid").append(newCard);
            }

            //$("#itemForm")[0].reset();
            $("#itemModal").modal("hide");
            //$currentCard = null;

            await saveTriggersToServer()
        });

        $("#gen-datetime").click(function () {
            let date = new Date();
            let dateString =
                date.getFullYear() + "-" +
                (date.getMonth() + 1) + "-" +
                date.getDate() + " " +
                date.getHours() + ":" +
                date.getMinutes() + ":" +
                date.getSeconds();
            const thenote = dateString;
            $("#noteInput").val($("#noteInput").val() + "\n" + thenote);
        })
    })

    async function saveTriggersToServer() {
        const note = [];
        let countedId = 0;
        $(".dashboard-card").each(function () {
            //alert($(this).data("title"))
            console.log(countedId)
            note.push({
                id: countedId.toString(),
                title: $(this).data("title").toString(),
                note: $(this).data("note").toString()
            });
            ++countedId;
        });

        console.log(note)
        const strTrigger = JSON.stringify({ note });
        fetch("/keepers/save", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: strTrigger
        })
            .then(res => res.json())
            .then(data => {
                console.log("Data stored:", data);
                window.location.reload();
            })
            .catch(err => {
                console.error("Failed to save:", err);
            });
    }
</script>